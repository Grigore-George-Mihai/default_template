<header data-controller="navigation">
  <nav class="navbar navbar-expand-lg">
    <div class="container">
      <%= link_to root_path, class: "navbar-brand" do %>
        <i class="fas fa-home"></i>
      <% end %>

      <button
        class="navbar-toggler"
        type="button"
        data-bs-toggle="collapse"
        data-bs-target="#navbarHeader"
        aria-controls="navbarHeader"
        aria-expanded="false"
        aria-label="Toggle navigation">
        <i class="fas fa-bars"></i>
      </button>

      <% if user_signed_in? %>
        <div class="collapse navbar-collapse" id="navbarHeader">
          <ul class="navbar-nav me-auto mb-2 mb-lg-0">
            <li class="nav-item">
              <%= link_to "Home", root_path, class: "nav-link", data: { navigation_target: "link" } %>
            </li>
          </ul>

          <ul class="navbar-nav ms-auto align-items-center gap-1">
            <% if current_user.admin? %>
              <li class="nav-item dropdown">
                <a
                  class="nav-link dropdown-toggle"
                  href="#"
                  id="adminDropdown"
                  role="button"
                  data-bs-toggle="dropdown"
                  aria-expanded="false">
                  Admin
                </a>
                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="adminDropdown">
                  <li><%= link_to "Admin Panel", admin_root_path, class: "dropdown-item", data: { navigation_target: "link" } %></li>
                  <% if Rails.env.development? %>
                    <li><hr class="dropdown-divider my-1"></li>
                    <li><%= link_to "Mailbox", letter_opener_web.letters_path, class: "dropdown-item", data: { navigation_target: "link" } %></li>
                  <% end %>
                </ul>
              </li>
            <% end %>

            <li class="nav-item dropdown">
              <a
                class="nav-link dropdown-toggle fw-medium"
                href="#"
                id="accountDropdown"
                role="button"
                data-bs-toggle="dropdown"
                aria-expanded="false">
                Account
              </a>
              <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="accountDropdown">
                <li class="dropdown-item-text text-muted small"><%= current_user.email %></li>
                <li><hr class="dropdown-divider my-1"></li>
                <li><%= link_to "Profile", edit_user_registration_path, class: "dropdown-item", data: { navigation_target: "link" } %></li>
                <li><hr class="dropdown-divider my-1"></li>
                <li><%= link_to "Sign out", destroy_user_session_path, class: "dropdown-item text-danger", data: { turbo_method: :delete } %></li>
              </ul>
            </li>
          </ul>
        </div>
      <% end %>
    </div>
  </nav>
</header>
